# Получите токен у @BotFather
BOT_TOKEN=123456:replace_me

# Telegram ID админов через запятую. Узнать ID можно через @userinfobot
ADMIN_IDS=123456789

# Сколько роботов создать при первом запуске, если база пустая
INITIAL_ROBOTS=3

# Данные для договора
COMPANY_NAME=ИП Иванов Иван Иванович
COMPANY_INN=000000000000
COMPANY_PHONE=+7 999 000-00-00
COMPANY_ADDRESS=г. Москва, ул. Примерная, 1
COMPANY_EMAIL=info@example.com

# Таймзона для дат и логов
TZ=Europe/Amsterdam
